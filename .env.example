# ─────────────────────────────────────────────────────────────
# JuiceShark configuration — copy this file to `.env` and fill in
# YOUR OWN API key. The .env file is gitignored and never committed.
#
#   cp .env.example .env
#
# JuiceShark auto-detects the provider: if OPENAI_API_KEY is set it uses
# OpenAI (recommended, default model gpt-4o-mini); otherwise it falls back
# to GEMINI_API_KEY. You only need ONE of the two.
# ─────────────────────────────────────────────────────────────

# Recommended. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional alternative. Get a key at https://aistudio.google.com/apikey
# NOTE: the free Gemini tier rate-limits (HTTP 429) partway through a scan.
GEMINI_API_KEY=
